# ===================================
# 🔥 FIREBASE CONFIG (Obrigatório)
# ===================================
# Obtenha em: https://console.firebase.google.com/
# Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ===================================
# 🤖 GOOGLE GEMINI AI (Obrigatório para KakaBot e Simulado)
# ===================================
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===================================
# ☁️ CLOUDINARY (Obrigatório para upload de imagens nos Resumos)
# ===================================
# Obtenha em: https://cloudinary.com/ → Dashboard → Account Details
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ===================================
# NOTAS:
# ===================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha TODOS os valores acima com suas credenciais reais
# 3. NUNCA commite o arquivo .env (já está no .gitignore)
# 4. Na Vercel: configure em Settings → Environment Variables
# 5. No GitHub Actions: configure em Settings → Secrets and Variables
# - Todas as chaves começam com VITE_ para serem expostas no frontend

