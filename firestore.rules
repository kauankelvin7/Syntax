rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // REGRAS DE SEGURANÇA — CINESIA
    // Gerado automaticamente com base na análise completa do sistema
    // ============================================================

    // ---- Funções auxiliares ----
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Verifica se o campo uid do documento pertence ao usuário autenticado
    function isDocOwner() {
      return isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Verifica se o campo uid sendo gravado pertence ao usuário autenticado
    function isCreatingAsOwner() {
      return isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // ============================================================
    // COLEÇÕES TOP-LEVEL (ownership via campo "uid")
    // ============================================================

    // -- MATÉRIAS --
    match /materias/{materiaId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }

    // -- RESUMOS --
    match /resumos/{resumoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }

    // -- FLASHCARDS --
    match /flashcards/{flashcardId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }

    // -- SIMULADOS --
    match /simulados/{simuladoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      // Simulados são imutáveis (não há update/delete no código)
    }

    // -- EVENTOS --
    match /eventos/{eventoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }

    // -- POMODORO --
    // Doc ID = "{userId}_{date}", também tem campo uid
    match /pomodoro/{docId} {
      allow read:   if isAuthenticated()
                    && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }

    // ============================================================
    // DOCUMENTO DO USUÁRIO + SUBCOLEÇÕES (ownership via path)
    // ============================================================

    match /users/{userId} {

      // -- Perfil do usuário --
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // -- Stats (streak, notifications_sent) --
      match /stats/{statId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      // -- Notificações --
      match /notifications/{notificationId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // -- Perfil do usuário (onboarding, preferências) --
      match /perfil/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      // -- KakaBot Memória (preferências e estatísticas) --
      match /kakabot_memoria/{docId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
      }

      // -- KakaBot Sessões (histórico paginado de conversas) --
      match /kakabot_sessoes/{sessaoId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // -- KakaBot Mensagens Salvas (favoritas/bookmarked) --
      match /kakabot_salvos/{salvoId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ============================================================
    // SOCIAL — Estude Juntos
    // ============================================================

    // -- USUÁRIOS (perfil público para busca) --
    // O perfil /users/{userId} original permite apenas owner.
    // Para buscas sociais, permitimos leitura autenticada de campos públicos.
    match /users/{userId} {
      allow read: if isAuthenticated();
    }

    // -- FRIENDSHIPS --
    // subscribeFriends        → where('users', 'array-contains', uid)
    // subscribePendingRequests → where('requestedTo', '==', uid)
    // subscribeSentRequests   → where('requestedBy', '==', uid)
    match /friendships/{friendshipId} {
      allow read:   if isAuthenticated() && (
                      resource == null ||
                      request.auth.uid in resource.data.users ||
                      resource.data.requestedTo   == request.auth.uid ||
                      resource.data.requestedBy   == request.auth.uid
                    );
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.requestedBy == request.auth.uid;
      allow update, delete: if isAuthenticated()
                    && request.auth.uid in resource.data.users;
    }

    // -- CONVERSAS --
    match /conversations/{conversationId} {
      // resource == null → doc não existe; permite read para que getDoc funcione
      // (a criação é protegida pela regra allow create abaixo)
      allow read: if isAuthenticated()
                    && (resource == null
                        || request.auth.uid in resource.data.participants);
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants;

      // Mensagens de uma conversa — somente participantes
      match /messages/{messageId} {
        allow read:   if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }

      // Typing indicators — somente participantes
      match /typing/{typingId} {
        allow read, write: if isAuthenticated()
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // -- DESAFIOS --
    match /challenges/{challengeId} {
      allow read: if isAuthenticated()
                    && (resource == null
                        || resource.data.inviterId == request.auth.uid
                        || resource.data.inviteeId == request.auth.uid);
      allow update: if isAuthenticated()
                    && (resource.data.inviterId == request.auth.uid
                        || resource.data.inviteeId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.inviterId == request.auth.uid;
    }

    // -- NOTIFICAÇÕES SOCIAIS --
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated()
                    && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    // ============================================================
    // BLOQUEAR TUDO QUE NÃO FOI EXPLICITAMENTE PERMITIDO
    // (regra padrão do Firestore — deny all by default)
    // ============================================================
  }
}
