rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isDocOwner() {
      return isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    function isCreatingAsOwner() {
      return isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /materias/{materiaId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }
    match /resumos/{resumoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }
    match /flashcards/{flashcardId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }
    match /simulados/{simuladoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
    }
    match /eventos/{eventoId} {
      allow read:   if isDocOwner();
      allow create: if isCreatingAsOwner();
      allow update: if isDocOwner() && isCreatingAsOwner();
      allow delete: if isDocOwner();
    }
    match /pomodoro/{docId} {
      allow read:   if isAuthenticated()
                    && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(userId);

      match /stats/{statId} {
        allow read, create, update: if isOwner(userId);
      }
      match /notifications/{notificationId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /perfil/{docId} {
        allow read, create, update: if isOwner(userId);
      }
      match /adabot_memoria/{docId} {
        allow read, create, update: if isOwner(userId);
      }
      match /adabot_sessoes/{sessaoId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /adabot_salvos/{salvoId} {
        allow read, create, delete: if isOwner(userId);
      }
      match /knowledgeMap/{conceptId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /roadmapProgress/{roadmapId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /analytics/{docId} {
        allow read, create, update: if isOwner(userId);
      }
      match /snippets/{snippetId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /integrations/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /githubAnalyses/{repoId} {
        allow read, create, update: if isOwner(userId);
      }
      match /interviewHistory/{interviewId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /feedCache/{docId} {
        allow read, create, update: if isOwner(userId);
      }
      match /readingList/{bookId} {
        allow read, create, update, delete: if isOwner(userId);
      }
      match /savedArticles/{articleId} {
        allow read, create, delete: if isOwner(userId);
      }
      match /conquistas/{conquistaId} {
        allow read, create, update: if isOwner(userId);
      }
      match /reviewerStats/{docId} {
        allow read, create, update: if isOwner(userId);
      }
      match /{subcol}/{docId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (
        resource == null ||
        request.auth.uid in resource.data.users ||
        resource.data.requestedTo == request.auth.uid ||
        resource.data.requestedBy == request.auth.uid
      );
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.requestedBy == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && request.auth.uid in resource.data.users;
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated()
        && (resource == null
            || request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, update: if isAuthenticated()
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId))
             .data.participants;
        allow create: if isAuthenticated()
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId))
             .data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
      match /typing/{typingId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid in
             get(/databases/$(database)/documents/conversations/$(conversationId))
             .data.participants;
      }
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated()
        && (resource == null
            || resource.data.inviterId == request.auth.uid
            || resource.data.inviteeId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.inviterId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.inviterId == request.auth.uid
            || resource.data.inviteeId == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated()
        && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.ownerId
            || request.auth.uid in resource.data.participants);
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.ownerId;

      match /messages/{msgId} {
        allow read, create: if isAuthenticated();
      }
    }

    match /communityFlashcards/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['upvotes','downvotes','voters','importCount','reports', 'likes', 'downloads'])
      );
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.authorId;
    }

    match /communityResumos/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['upvotes','downvotes','voters','importCount','reports', 'likes', 'downloads'])
      );
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.authorId;
    }

    match /peerReviews/{reviewId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.authorId;

      match /comments/{commentId} {
        allow read, create: if isAuthenticated();
        allow update: if isAuthenticated()
          && (request.auth.uid == resource.data.authorId
              || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['resolved']));
      }
    }
  }
}
